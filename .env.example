# x402 Payment Configuration (from @lucid-dreams/agent-kit)
# These are required for the x402 paywall to work

# Your EVM wallet address (receives payments)
ADDRESS=0xYourWalletAddress

# x402 facilitator URL
FACILITATOR_URL=https://facilitator.daydreams.ai

# Network for payments (base-sepolia for testing, base for production)
NETWORK=base-sepolia

# Price per call in smallest unit (USDC: 6 decimals, 1000 = $0.001)
DEFAULT_PRICE=1000

# Port for the HTTP server
PORT=8080
